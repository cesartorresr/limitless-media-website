# Configuración básica de LiteSpeed
<IfModule Litespeed>
    RewriteEngine On
    RewriteBase /
    
    # Prevenir listado de directorios
    Options -Indexes
    
    # Redirigir todo a index.html si no es un archivo o carpeta existente
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ /index.html [L]
</IfModule>

# Asegurar permisos básicos para que todos los archivos sean accesibles
<FilesMatch "\.(html|css|js|png|jpg|svg|ico|json|woff|woff2|ttf|eot|otf|webp)$">
    Require all granted
</FilesMatch>

# Manejo de errores
# Redirige errores 403 y 404 a index.html para asegurar que el SPA maneje las rutas
ErrorDocument 403 /index.html
ErrorDocument 404 /index.html

# Controlar el caché del navegador para recursos estáticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType application/json "access plus 1 month"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
</IfModule>